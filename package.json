{
  "name": "image-optimizer-pro",
  "version": "0.1.0",
  "description": "Production-grade AVIF and WebP image optimization for Node.js, CLIs, and modern JavaScript frameworks.",
  "license": "MIT",
  "author": "image-optimizer-pro contributors",
  "keywords": [
    "image",
    "optimizer",
    "optimization",
    "avif",
    "webp",
    "sharp",
    "cli",
    "compression",
    "nextjs",
    "react",
    "vue",
    "nodejs",
    "build-tool",
    "asset-pipeline"
  ],
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "img-optimize": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "benchmark": "npm run build && node ./benchmarks/run.mjs",
    "pack:check": "npm pack --dry-run",
    "check": "npm run lint && npm run format && npm run typecheck && npm run test && npm run build",
    "prepack": "npm run build",
    "prepare": "node ./scripts/prepare.mjs",
    "release": "semantic-release"
  },
  "overrides": {
    "brace-expansion": "^2.0.3",
    "picomatch": "^4.0.4"
  },
  "lint-staged": {
    "*.{ts,mts,cts,js,mjs,cjs}": [
      "eslint --max-warnings=0 --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "picomatch": "^4.0.4",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.25.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.0",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/node": "^22.15.3",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "semantic-release": "^25.0.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2"
  }
}
